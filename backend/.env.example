# ── Required ──────────────────────────────────────────────────────────────────
PORT=5001
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/crm_db?retryWrites=true&w=majority
JWT_SECRET=<generate-a-64+-character-random-string-here>
NODE_ENV=development

# ── Admin Seeder ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@crm.com
ADMIN_PASSWORD=YourSecurePassword123!

# ── Email / OTP ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── Cloudinary (File Uploads) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id

# ── CORS (comma-separated production origins) ────────────────────────────────
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com
